DirectoryIndex index.php
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /shop/
RewriteRule ^product/([a-z][a-z0-9_-]*)/?$ product.php?id=$1 [L,QSA]
RewriteRule ^(fashion-boutiques|electronics|home-interior|sports-fitness|beauty|food-gourmet|b2b-wholesale|marketplace)/?$ vertical.php?slug=$1 [L,QSA]
ErrorDocument 404 /shop/404.php
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule ^$ index.php [L]
RewriteRule ^sitemap\.xml$ sitemap-index.php [L]
RewriteRule ^sitemap-pages\.xml$ sitemap-pages.php [L]
RewriteRule ^sitemap-products\.xml$ sitemap-products.php [L]
RewriteRule ^sitemap-categories\.xml$ sitemap-categories.php [L]
RewriteRule ^sitemap-verticals\.xml$ sitemap-verticals.php [L]
RewriteRule ^sitemap-news\.xml$ sitemap-news.php [L]
RewriteRule ^api/quick-buy\.php$ api/quick-buy.php [L]
RewriteRule ^(index|search|product|cart|contact|page|track|news|news-article|sitemap|sitemap-index|sitemap-pages|sitemap-products|sitemap-categories|sitemap-verticals|sitemap-news|solutions|vertical)\.php$ - [L]
RewriteRule . 404.php [L]
</IfModule>